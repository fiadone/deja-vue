{
  "name": "deja-vue-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:docs": "npm run build -w @deja-vue/docs",
    "build:landing": "npm run build -w @deja-vue/landing",
    "build:lib": "npm run build -w deja-vue",
    "dev:docs": "npm run dev -w @deja-vue/docs",
    "dev:landing": "npm run dev -w @deja-vue/landing",
    "dev:lib": "npm run dev -w deja-vue",
    "preview:docs": "npm run preview -w @deja-vue/docs",
    "preview:landing": "npm run preview -w @deja-vue/landing",
    "lint": "npm run lint:script && npm run lint:style",
    "lint:fix": "npm run lint:script:fix && npm run lint:style:fix",
    "lint:script": "eslint .",
    "lint:script:fix": "eslint . --fix",
    "lint:style": "stylelint \"**/*.{css,vue}\"",
    "lint:style:fix": "stylelint \"**/*.{css,vue}\" --fix",
    "release": "npm run release -w deja-vue",
    "test": "npm run test -w deja-vue",
    "test:coverage": "npm run test:coverage -w deja-vue",
    "typecheck": "npm run typecheck -w deja-vue && npm run typecheck -w @deja-vue/landing && npm run typecheck -w @deja-vue/docs",
    "commit": "cz"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-config": "^5.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "stylelint": "^17.11.1",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript-eslint": "^8.59.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
